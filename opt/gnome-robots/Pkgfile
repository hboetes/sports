# Description: lovely silly robos game
# URL:         https://github.com/GNOME/gnome-robots.git
# Dependencies: rust

name=gnome-robots
version=git
release=1
source=(https://github.com/GNOME/gnome-robots.git)

build()
{
    cd $name
    meson_build
}

post-install()
{
    glib-compile-schemas /usr/local/share/glib-2.0/schemas/
}
