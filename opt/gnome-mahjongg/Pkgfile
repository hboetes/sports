# Description: Single-player tile-matching game, commonly known as Mahjong solitaire.

name=gnome-mahjongg
version=git
release=1
source=(https://github.com/GNOME/gnome-mahjongg.git)

build()
{
    cd $name
    meson_build
}

post-install()
{
    glib-compile-schemas /usr/local/share/glib-2.0/schemas/
}
