# Description:  swaylock fork
# URL:          https://github.com/hboetes/swaylock-effects.git
# Dependencies: fprintd-devel

name=swaylock-effects
version=git
release=1
branch=master
source=(
    https://github.com/hboetes/swaylock-effects.git
)

build()
{
    cd $name

    meson_build \
        --sysconfdir=/etc \
        --prefix=/usr/local \
        -Dgdk-pixbuf=enabled \
        -Dzsh-completions=true \
        -Dbash-completions=false \
        -Dfish-completions=false \
        -Dfingerprint=enabled
}
