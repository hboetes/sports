# Description:  swaylock fork
# URL:          https://github.com/hboetes/swaylock-effects.git
# Dependencies: fprintd-devel

name=swaylock-effects
version=git
release=1
branch=master
source=(
    https://github.com/hboetes/swaylock-effects.git
    swaylock-effects-clock-boottime.patch
    swaylock-effects-single-instance.patch
    swaylock-effects-fingerprint-resume.patch
)

build()
{
    cd $name
    patch_apply swaylock-effects-clock-boottime
    patch_apply swaylock-effects-single-instance
    patch_apply swaylock-effects-fingerprint-resume

    meson_build \
        --sysconfdir=/etc \
        --prefix=/usr/local \
        -Dgdk-pixbuf=enabled \
        -Dzsh-completions=true \
        -Dbash-completions=false \
        -Dfish-completions=false \
        -Dfingerprint=enabled
}
